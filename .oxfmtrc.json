{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    ".git",
    "public",
    "src/assets",
    "*.min.js",
    "*.map",
    ".cache",
    "pnpm-lock.yaml",
    "pnpm-lock.yaml",
    "vite.config.*"
  ]
}
